[Unit]
Description=Add Flatpak Repos
ConditionPathExists=!/var/lib/flatpak/.zodium-flatpak-added
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
ExecStart=/usr/bin/flatpak remote-modify --no-filter --enable flathub
ExecStartPost=/usr/bin/touch /var/lib/flatpak/.zodium-flatpak-added

[Install]
WantedBy=graphical.target